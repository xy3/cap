    "margin_right": 60,
    "margin_top": 20,
    "margin_bottom": 100
  },
  "whisper": {
    "mode": "local",
    "model": "",
    "language": "en",
    "prompt": "",
    "temperature": 0.0,
    "binary_path": "whisper",
    "model_path": "base"
