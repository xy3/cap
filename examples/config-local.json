{
  "chars_per_frame": 24,
  "display_mode": "static",
  "output_path": "output_local.mp4",
  "resolution": "1920x1080",
  "font": {
    "family": "Arial",
    "size": 48,
    "color": "#FFFFFF",
    "bold": false,
    "italic": false,
    "underline": false
  },
